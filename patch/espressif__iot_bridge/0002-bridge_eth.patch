@@ -448,6 +448,8 @@ esp_netif_t* esp_bridge_create_eth_netif(esp_netif_ip_info_t* ip_info, uint8_t m
 #elif CONFIG_BRIDGE_USE_SPI_ETHERNET
         esp_bridge_eth_spi_init(netif);
