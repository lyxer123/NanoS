diff --git a/src/bridge_eth.c b/src/bridge_eth.c
index 0000000..0000000 100644
--- a/src/bridge_eth.c
+++ b/src/bridge_eth.c
@@ -372,7 +372,12 @@ static esp_err_t esp_bridge_eth_reset_phy(void)
 
